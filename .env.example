# Copy to .env (kept out of git). The package-root .env is loaded
# automatically; variables already set in the real environment win.

# Base dir for runtime data (caches, logs, sidecar). Defaults to the package dir.
GMAP_HOME=

# REQUIRED for browser operations: a persistent Chromium profile already logged
# into Google. Create one with: npm run login
GOOGLE_MAPS_PROFILE=/absolute/path/to/your/google-maps-profile

# Optional path overrides (default under $GMAP_HOME):
GMAP_REGION_CONFIG=
GMAP_CACHE=
GMAP_SOCIAL_CACHE=
GMAP_BENCHMARK_LOG=
GMAP_FAILURE_DIR=
GMAP_SIDECAR_DIR=

# Tuning (blank values fall back to the defaults shown):
GMAP_RETRIES=2
GMAP_RETRY_MIN_TIMEOUT_MS=750
# Set to 0 to run the browser headed (visible) — e.g. to debug a save.
HEADLESS=
# Set to 0 to disable the high-confidence social fast path (always use the browser).
GMAP_FAST_SOCIAL=
# Optional: let yt-dlp reuse your browser cookies for captions.
YTDLP_COOKIES_FROM_BROWSER=
# Optional: start URL for scripts/login.js (default: https://www.google.com/maps).
START_URL=
